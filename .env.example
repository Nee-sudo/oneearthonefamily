# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# MongoDB: Connection URI string instead of Firebase
# Users configure this via the Secrets panel in AI Studio with the name Mongo_ur or MONGO_URI
Mongo_ur=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/oneearth?retryWrites=true&w=majority

